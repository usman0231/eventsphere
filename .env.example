# ── EventSphere environment variables ──────────────────────────────
# On Vercel: add these in Project → Settings → Environment Variables.
# Locally: copy this file to ".env.local" at the PROJECT ROOT (Next.js reads it).
# NOTE: Next.js only loads .env* from the repo root — NOT from lib/server/.

# Database (MongoDB Atlas connection string)
MONGO_URI=mongodb+srv://USER:PASS@cluster.xxxxx.mongodb.net/eventsphere

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE=7d
# Optional dedicated secret for signing QR check-in tokens (falls back to JWT_SECRET)
CHECKIN_SECRET=

# Public base URL — used to build links inside verification / password-reset emails.
# Local dev: http://localhost:3000   |   Production: your Vercel domain (https://...).
# Do NOT use a LAN IP (e.g. 192.168.x.x) — those links only work on one network.
CLIENT_URL=http://localhost:3000

# Image uploads (Cloudinary — free tier: https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email (SMTP for verify / password-reset mails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
SMTP_FROM="EventSphere <no-reply@example.com>"

# Chatbot (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Cron protection — set this so only Vercel Cron can trigger the reminder job.
# Vercel automatically sends "Authorization: Bearer <CRON_SECRET>" to cron paths.
CRON_SECRET=change-me-to-a-long-random-string

# ── Notes ──────────────────────────────────────────────────────────
# Frontend + API share one origin (Next.js), so no API base URL is needed.
# NEXT_PUBLIC_SOCKET_URL (client) is optional — leave unset to disable live
# Socket.IO (notifications still work via fetch/refresh).
# NEXT_PUBLIC_API_URL (client) is optional — only set to point at a different API origin.
